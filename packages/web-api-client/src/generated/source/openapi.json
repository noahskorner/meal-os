              "name": {
                "type": "string",
                "example": "each"
              },
              "abbreviation": {
                "type": "string",
                "example": "ea"
              },
              "type": {
                "type": "string",
                "example": "COUNT"
              }
            },
            "required": ["id", "name", "abbreviation", "type"]
          }
        },
        "required": ["id", "name", "aliases", "category", "defaultUnit"]
      },
