          "name": {
            "type": "string",
            "example": "cup"
          },
          "abbreviation": {
            "type": "string",
            "example": "cup"
          },
          "type": {
            "type": "string",
            "example": "VOLUME"
          }
        },
        "required": ["id", "name", "abbreviation", "type"]
      }
