      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"],
            "example": "ok"
          },
          "service": {
            "type": "string",
            "enum": ["web"],
            "example": "web"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-19T14:00:00.000Z"
          }
        },
        "required": ["status", "service"]
      },
      "HealthCheckValidationErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Invalid query parameters."
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "includeTimestamp: Invalid option: expected one of \"true\"|\"false\""
            ]
          }
        },
        "required": ["message", "issues"]
      },
      "ListIngredientsResponse": {
        "type": "object",
