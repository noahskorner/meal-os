          },
          "page": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "example": 1
          },
          "pageSize": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "example": 20
          },
          "totalItems": {
            "type": "integer",
            "minimum": 0,
            "example": 120
          },
          "totalPages": {
            "type": "integer",
            "minimum": 0,
            "example": 6
          }
        },
        "required": ["items", "page", "pageSize", "totalItems", "totalPages"]
      },
