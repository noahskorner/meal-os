generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model Profile {
  id             String   @id @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  mealPlans      MealPlan[]
  recipes        Recipe[]
  userIngredients UserIngredient[]

  @@map("profiles")
  @@schema("public")
}

enum UnitType {
  WEIGHT  @map("weight")
  VOLUME  @map("volume")
  COUNT   @map("count")
  PACKAGE @map("package")

  @@map("unit_types")
  @@schema("public")
}

model Recipe {
  id                String             @id @default(uuid()) @db.Uuid
  createdById       String             @map("created_by_id") @db.Uuid
  name              String
  description       String?            @db.Text
  prepTimeMinutes   Int?               @map("prep_time_minutes")
  cookTimeMinutes   Int?               @map("cook_time_minutes")
  servings          Int?
  createdBy         Profile            @relation(fields: [createdById], references: [id])
  mealPlanEntryRecipes MealPlanEntryRecipe[]
  recipeIngredients RecipeIngredient[]
  recipeSteps       RecipeStep[]
  recipeRecipeTags  RecipeRecipeTag[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "recipes_name_trigram_idx")
  @@map("recipes")
  @@schema("public")
}

model MealPlan {
  id          String          @id @default(uuid()) @db.Uuid
  createdById String          @map("created_by_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy   Profile         @relation(fields: [createdById], references: [id])
  entries     MealPlanEntry[]

  @@index([createdById])
  @@map("meal_plans")
  @@schema("public")
}

model MealPlanEntry {
  id                  String                @id @default(uuid()) @db.Uuid
  mealPlanId          String                @map("meal_plan_id") @db.Uuid
  date                DateTime              @db.Date
  mealPlan            MealPlan              @relation(fields: [mealPlanId], references: [id])
  mealPlanEntryRecipes MealPlanEntryRecipe[]

  @@unique([mealPlanId, date])
  @@map("meal_plan_entries")
  @@schema("public")
}

model MealPlanEntryRecipe {
  id              String        @id @default(uuid()) @db.Uuid
  mealPlanEntryId String        @map("meal_plan_entry_id") @db.Uuid
  recipeId        String        @map("recipe_id") @db.Uuid
  sortOrder       Int           @map("sort_order")
  mealPlanEntry   MealPlanEntry @relation(fields: [mealPlanEntryId], references: [id])
  recipe          Recipe        @relation(fields: [recipeId], references: [id])

  @@unique([mealPlanEntryId, sortOrder])
  @@map("meal_plan_entry_recipes")
  @@schema("public")
}

model RecipeIngredient {
  id               String         @id @default(uuid()) @db.Uuid
  recipeId         String         @map("recipe_id") @db.Uuid
  ingredientId     String?        @map("ingredient_id") @db.Uuid
  userIngredientId String?        @map("user_ingredient_id") @db.Uuid
  name             String
  quantity         Decimal?       @db.Decimal(10, 2)
  unitId           String?        @map("unit_id") @db.Uuid
  preparation      String?        @db.Text
  note             String?        @db.Text
  isOptional       Boolean?       @map("is_optional")
  recipe           Recipe         @relation(fields: [recipeId], references: [id])
  ingredient       Ingredient?    @relation(fields: [ingredientId], references: [id])
  userIngredient   UserIngredient? @relation(fields: [userIngredientId], references: [id])
  unit             Unit?          @relation(fields: [unitId], references: [id])

  @@map("recipe_ingredients")
  @@schema("public")
}

model RecipeStep {
  id        String @id @default(uuid()) @db.Uuid
  recipeId  String @map("recipe_id") @db.Uuid
  text      String @db.Text
  sortOrder Int    @map("sort_order")
  recipe    Recipe @relation(fields: [recipeId], references: [id])

  @@unique([recipeId, sortOrder])
  @@map("recipe_steps")
  @@schema("public")
}

model RecipeTag {
  id               String            @id @default(uuid()) @db.Uuid
  name             String            @unique
  recipeRecipeTags RecipeRecipeTag[]

  @@map("recipe_tags")
  @@schema("public")
}

model RecipeRecipeTag {
  id          String    @id @default(uuid()) @db.Uuid
  recipeId    String    @map("recipe_id") @db.Uuid
  recipeTagId String    @map("recipe_tag_id") @db.Uuid
  recipe      Recipe    @relation(fields: [recipeId], references: [id])
  recipeTag   RecipeTag @relation(fields: [recipeTagId], references: [id])

  @@unique([recipeId, recipeTagId])
  @@map("recipe_recipe_tags")
  @@schema("public")
}

model Ingredient {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @unique
  categoryId        String             @map("category_id") @db.Uuid
  defaultUnitId     String             @map("default_unit_id") @db.Uuid
  category          IngredientCategory @relation(fields: [categoryId], references: [id])
  defaultUnit       Unit               @relation(fields: [defaultUnitId], references: [id])
  aliases           IngredientAlias[]
  recipeIngredients RecipeIngredient[]

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "ingredients_name_trigram_idx")
  @@map("ingredients")
  @@schema("public")
}

model UserIngredient {
  id                String             @id @default(uuid()) @db.Uuid
  createdById       String             @map("created_by_id") @db.Uuid
  name              String
  categoryId        String?            @map("category_id") @db.Uuid
  defaultUnitId     String?            @map("default_unit_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy         Profile            @relation(fields: [createdById], references: [id])
  category          IngredientCategory? @relation(fields: [categoryId], references: [id])
  defaultUnit       Unit?              @relation(fields: [defaultUnitId], references: [id])
  recipeIngredients RecipeIngredient[]

  @@unique([createdById, name])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "user_ingredients_name_trigram_idx")
  @@map("user_ingredients")
  @@schema("public")
}

model IngredientCategory {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  ingredients Ingredient[]
  userIngredients UserIngredient[]

  @@map("ingredient_categories")
  @@schema("public")
}

model IngredientAlias {
  ingredientId String     @map("ingredient_id") @db.Uuid
  alias        String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([ingredientId, alias])
  @@index([alias(ops: raw("gin_trgm_ops"))], type: Gin, map: "ingredient_aliases_alias_trigram_idx")
  @@map("ingredient_aliases")
  @@schema("public")
}

model Unit {
  id                String             @id @default(uuid()) @db.Uuid
  type              UnitType
  name              String             @unique
  abbreviation      String
  ingredients       Ingredient[]
  userIngredients   UserIngredient[]
  recipeIngredients RecipeIngredient[]

  @@map("units")
  @@schema("public")
}
